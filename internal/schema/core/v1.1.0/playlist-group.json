{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dp1.feralfile.com/schemas/v1.1.0/playlist-group.json",
  "title": "DP-1 Playlist Group (Exhibition)",
  "description": "A curator-authored collection of one or more playlists with shared metadata",
  "type": "object",
  "required": ["id", "title", "playlists", "created"],
  "anyOf": [
    {
      "required": ["signatures"]
    },
    {
      "required": ["signature"]
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the playlist group (UUID v4)",
      "format": "uuid"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly identifier for the playlist group",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title for the playlist group/exhibition",
      "minLength": 1,
      "maxLength": 200
    },
    "curator": {
      "type": "string",
      "description": "Name of the curator who created this exhibition"
    },
    "summary": {
      "type": "string",
      "description": "Brief description or curatorial statement for the exhibition"
    },
    "playlists": {
      "type": "array",
      "description": "Ordered array of playlist URIs included in this exhibition",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri",
        "description": "URI to a DP-1 playlist JSON file"
      }
    },
    "created": {
      "type": "string",
      "description": "ISO 8601 timestamp when the playlist group was created",
      "format": "date-time"
    },
    "coverImage": {
      "type": "string",
      "description": "URI to a cover image for the exhibition",
      "format": "uri"
    },
    "signatures": {
      "type": "array",
      "description": "Multi-signature chain (v1.1.0+)",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Signature"
      }
    },
    "signature": {
      "type": "string",
      "description": "Legacy single signature (v1.0.x, deprecated)",
      "pattern": "^ed25519:[a-f0-9]+$",
      "deprecated": true
    }
  },
  "$defs": {
    "Signature": {
      "type": "object",
      "description": "Multi-signature object (v1.1.0+)",
      "required": ["alg", "kid", "ts", "payload_hash", "role", "sig"],
      "properties": {
        "alg": {
          "type": "string",
          "description": "Signature algorithm",
          "enum": ["ed25519", "eip191", "ecdsa-secp256k1", "ecdsa-p256"]
        },
        "kid": {
          "type": "string",
          "description": "Key identifier in W3C DID format",
          "pattern": "^did:[a-z]+:.+$"
        },
        "ts": {
          "type": "string",
          "description": "ISO 8601 timestamp when signature was created",
          "format": "date-time"
        },
        "payload_hash": {
          "type": "string",
          "description": "SHA-256 hash of canonical playlist-group payload",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "role": {
          "type": "string",
          "description": "Role of the signing entity",
          "enum": ["curator", "feed", "agent", "institution", "licensor"]
        },
        "sig": {
          "type": "string",
          "description": "Base64url-encoded signature bytes (no padding)",
          "pattern": "^[A-Za-z0-9_-]+$"
        }
      }
    }
  }
}
